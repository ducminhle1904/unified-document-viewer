{
  "name": "keyloop-scenario-d",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "web:dev": "vite --config apps/web/vite.config.ts",
    "web:preview": "vite preview --config apps/web/vite.config.ts",
    "web:build": "tsc -p apps/web/tsconfig.json --noEmit && vite build --config apps/web/vite.config.ts",
    "web:test": "vitest run --config apps/web/vitest.config.ts",
    "web:e2e": "playwright test -c apps/web/playwright.config.ts",
    "reset-db": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.12",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fastify": "^5.2.1",
    "pino": "^10.3.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.0",
    "vitest": "^4.1.7"
  }
}
